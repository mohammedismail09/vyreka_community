# Django secret key
# Use any strong random string locally.
# In production, always use a secure private value.
SECRET_KEY=your-production-or-dev-secret-key

# Django debug mode
# True for local development, False for production.
DEBUG=True


# Email / SMTP configuration for contact form
# Gmail SMTP settings are used here.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Gmail account used to send emails
EMAIL_HOST_USER=

# Gmail App Password, not your normal Gmail password
EMAIL_HOST_PASSWORD=

# Sender name shown in outgoing emails
DEFAULT_FROM_EMAIL=Vyreka Hyderabad Community <vyrekaedtech@gmail.com>


# Django allowed hosts
# Comma-separated values, no spaces if your parser is strict
ALLOWED_HOSTS=127.0.0.1,localhost

# Frontend origins allowed to call backend APIs
# Local Vite dev server URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Trusted frontend origins for CSRF-protected requests
CSRF_TRUSTED_ORIGINS=http://localhost:5173


# Frontend backend base URL
# Used by the Vite frontend for API requests
VITE_BACKEND_URL=http://127.0.0.1:8000